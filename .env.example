WEAVIATE_HOST_URL=weaviate
WEAVIATE_PORT=8080
WEAVIATE_GRPC_HOST_URL=weaviate
WEAVIATE_GRPC_PORT=50051
WEAVIATE_SECURE=false
WEAVIATE_RESET_SCHEMA=false

# Import behavior
# Keep existing Weaviate data by default. Set true to clear Testimonies and Chunks before import.
RESET_WEAVIATE_DATA=false
# Skip interviews that already have a Testimonies object and at least one Chunk.
SKIP_IMPORTED_INTERVIEWS=true

# Chat API keys
# Choose provider/model/baseUrl in config.json under features.chat.
# Keep only the key for the provider you use.

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# OpenAI-compatible providers (optional fallback key name)
AI_API_KEY=

# Zotero OAuth 1.0a credentials (required when features.zotero.enabled = true)
# Register your app at https://www.zotero.org/oauth/apps
ZOTERO_CLIENT_KEY=
ZOTERO_CLIENT_SECRET=
# 32-byte hex string for AES-256-GCM cookie encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ZOTERO_COOKIE_SECRET=
